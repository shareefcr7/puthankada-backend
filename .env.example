# MongoDB Configuration (Cloud Atlas)
MONGO_URI=mongodb+srv://your_user:your_password@your_cluster.mongodb.net/your_database

# JWT Secret
JWT_SECRET=your-jwt-secret-key

# Environment
# Set to 'production' on Render (server will bind to 0.0.0.0)
# Set to 'development' locally (server will bind to 127.0.0.1)
NODE_ENV=development

# Port
PORT=5001

# CORS Configuration (comma-separated list of allowed origins)
ALLOWED_ORIGINS=https://your-frontend.vercel.app,https://your-admin.vercel.app,https://yourdomain.com,http://localhost:3000,http://localhost:3001

# Cloudinary Configuration (Image Upload Service)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret